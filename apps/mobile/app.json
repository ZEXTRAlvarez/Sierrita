{
  "expo": {
    "name": "Sierrita",
    "slug": "orgmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icono-fav.png",
    "scheme": "sierrita",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rodaalvarez.sierrita"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icono-fav.png",
        "backgroundColor": "#BBE3F7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rodaalvarez.sierrita"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#BBE3F7"
        }
      ],
      "expo-sharing",
      "expo-sqlite",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "070d429a-4abc-4169-8788-df805c18071c"
      }
    },
    "owner": "rodaaa"
  }
}

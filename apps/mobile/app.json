{
  "expo": {
    "name": "Sierrita",
    "slug": "@org/mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icono-fav.png",
    "scheme": "sierrita",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icono-fav.png",
        "backgroundColor": "#BBE3F7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.orgmobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#BBE3F7"
        }
      ],
      "expo-sharing",
      "expo-sqlite",
      "expo-image"
    ]
  }
}
